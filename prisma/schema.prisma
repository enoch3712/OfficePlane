// OfficePlane Database Schema with Prisma
// Extends existing PostgreSQL + pgvector setup

// Generate Python client for FastAPI backend
generator py {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

// Generate JavaScript client for Next.js UI
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// EXISTING SCHEMA (from init.sql)
// ============================================================

enum DocumentStatus {
  DRAFT
  REVIEW
  APPROVED
  ARCHIVED

  @@map("document_status")
}

model Document {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  author       String?
  metadata     Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime       @updatedAt @map("updated_at") @db.Timestamptz
  // Original file storage
  sourceFile   Bytes?         @map("source_file")
  sourceFormat String?        @map("source_format") // 'docx', 'pdf', etc.
  fileName     String?        @map("file_name")
  summary       String?       @db.Text
  topics        String[]      @default([])
  keyEntities   Json          @default("{}") @map("key_entities")
  summaryModel  String?       @map("summary_model")
  summarizedAt  DateTime?     @map("summarized_at") @db.Timestamptz
  status        DocumentStatus @default(DRAFT)

  // Relations
  chapters    Chapter[]
  chunks      Chunk[]
  tasks       Task[]
  history     ExecutionHistory[]
  collections DocumentCollection[]
  derivations Derivation[]
  statusEvents DocumentStatusEvent[]
  tags         DocumentTag[]
  retentions   DocumentRetention[]

  @@map("documents")
}

model DocumentStatusEvent {
  id          String          @id @default(uuid()) @db.Uuid
  documentId  String          @map("document_id") @db.Uuid
  fromStatus  DocumentStatus? @map("from_status")
  toStatus    DocumentStatus  @map("to_status")
  actor       String?
  note        String?
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  document    Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId], name: "idx_status_event_document")
  @@index([createdAt], name: "idx_status_event_created")
  @@map("document_status_events")
}

model Collection {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  description String?
  parentId    String?  @map("parent_id") @db.Uuid
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  parent   Collection?  @relation("CollectionHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Collection[] @relation("CollectionHierarchy")
  documents DocumentCollection[]

  @@index([parentId], name: "idx_collections_parent")
  @@index([name], name: "idx_collections_name")
  @@map("collections")
}

model DocumentCollection {
  documentId   String   @map("document_id") @db.Uuid
  collectionId String   @map("collection_id") @db.Uuid
  addedAt      DateTime @default(now()) @map("added_at") @db.Timestamptz

  document   Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)
  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  @@id([documentId, collectionId])
  @@index([collectionId], name: "idx_doc_coll_collection")
  @@index([documentId], name: "idx_doc_coll_document")
  @@map("document_collections")
}

model Chapter {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  title      String
  orderIndex Int      @map("order_index")
  summary    String?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  document Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  sections Section[]
  chunks   Chunk[]

  @@index([documentId], name: "idx_chapters_document")
  @@index([documentId, orderIndex], name: "idx_chapters_order")
  @@map("chapters")
}

model Section {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  chapterId  String   @map("chapter_id") @db.Uuid
  title      String
  orderIndex Int      @map("order_index")
  summary    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  pages   Page[]
  chunks  Chunk[]

  @@index([chapterId], name: "idx_sections_chapter")
  @@index([chapterId, orderIndex], name: "idx_sections_order")
  @@map("sections")
}

model Page {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sectionId  String   @map("section_id") @db.Uuid
  pageNumber Int      @map("page_number")
  content    String   @default("")
  wordCount  Int      @default(0) @map("word_count")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  chunks  Chunk[]

  @@index([sectionId], name: "idx_pages_section")
  @@index([sectionId, pageNumber], name: "idx_pages_order")
  @@map("pages")
}

model Chunk {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  documentId  String   @map("document_id") @db.Uuid
  chapterId   String   @map("chapter_id") @db.Uuid
  sectionId   String   @map("section_id") @db.Uuid
  pageId      String   @map("page_id") @db.Uuid
  text        String
  startOffset Int      @map("start_offset")
  endOffset   Int      @map("end_offset")
  tokenCount  Int      @default(0) @map("token_count")
  embedding   Unsupported("vector(768)")?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  chapter  Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  section  Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  page     Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([documentId], name: "idx_chunks_document")
  @@index([chapterId], name: "idx_chunks_chapter")
  @@index([pageId], name: "idx_chunks_page")
  @@map("chunks")
}

// ============================================================
// NEW: TASK QUEUE SYSTEM
// ============================================================

enum TaskState {
  QUEUED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
  RETRYING
  TIMEOUT

  @@map("task_state")
}

enum TaskPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL

  @@map("task_priority")
}

model Task {
  id                 String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskType           String        @map("task_type")
  taskName           String?       @map("task_name")
  documentId         String?       @map("document_id") @db.Uuid
  parentTaskId       String?       @map("parent_task_id") @db.Uuid
  payload            Json          @default("{}")
  result             Json?
  state              TaskState     @default(QUEUED)
  priority           TaskPriority  @default(NORMAL)
  maxRetries         Int           @default(3) @map("max_retries")
  retryCount         Int           @default(0) @map("retry_count")
  retryDelaySeconds  Int           @default(5) @map("retry_delay_seconds")
  backoffMultiplier  Float         @default(2.0) @map("backoff_multiplier")
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz
  scheduledFor       DateTime      @default(now()) @map("scheduled_for") @db.Timestamptz
  startedAt          DateTime?     @map("started_at") @db.Timestamptz
  completedAt        DateTime?     @map("completed_at") @db.Timestamptz
  timeoutSeconds     Int           @default(300) @map("timeout_seconds")
  errorMessage       String?       @map("error_message")
  errorStack         String?       @map("error_stack")
  workerId           String?       @map("worker_id")
  workerHost         String?       @map("worker_host")
  metadata           Json          @default("{}")
  tags               String[]      @default([])

  // Relations
  document    Document?          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parentTask  Task?              @relation("TaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subTasks    Task[]             @relation("TaskHierarchy")
  retries     TaskRetry[]
  history     ExecutionHistory[]

  @@index([state, scheduledFor], name: "idx_queue_state")
  @@index([priority(sort: Desc), createdAt], name: "idx_queue_priority")
  @@index([documentId], name: "idx_queue_document")
  @@index([parentTaskId], name: "idx_queue_parent")
  @@index([createdAt(sort: Desc)], name: "idx_queue_created")
  @@map("task_queue")
}

// ============================================================
// NEW: EXECUTION HISTORY
// ============================================================

enum EventType {
  // Instance events
  INSTANCE_CREATED
  INSTANCE_OPENED
  INSTANCE_USED
  INSTANCE_CLOSED
  INSTANCE_ERROR
  INSTANCE_HEARTBEAT

  // Task events
  TASK_QUEUED
  TASK_STARTED
  TASK_COMPLETED
  TASK_FAILED
  TASK_RETRY
  TASK_CANCELLED
  TASK_TIMEOUT

  // Document events
  DOCUMENT_CREATED
  DOCUMENT_IMPORTED
  DOCUMENT_EXPORTED
  DOCUMENT_EDITED
  DOCUMENT_DELETED

  // System events
  SYSTEM_STARTUP
  SYSTEM_SHUTDOWN
  WORKER_STARTED
  WORKER_STOPPED

  @@map("event_type")
}

model ExecutionHistory {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType    EventType @map("event_type")
  eventMessage String?   @map("event_message")
  documentId   String?   @map("document_id") @db.Uuid
  taskId       String?   @map("task_id") @db.Uuid
  timestamp    DateTime  @default(now()) @db.Timestamptz
  durationMs   Int?      @map("duration_ms")
  actorType    String?   @map("actor_type") // 'user', 'worker', 'system', 'api'
  actorId      String?   @map("actor_id")
  metadata     Json      @default("{}")
  traceId      String?   @map("trace_id")
  parentTraceId String?  @map("parent_trace_id")

  // Relations
  document Document?          @relation(fields: [documentId], references: [id], onDelete: SetNull)
  task     Task?              @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([timestamp(sort: Desc)], name: "idx_history_timestamp")
  @@index([eventType], name: "idx_history_event_type")
  @@index([documentId], name: "idx_history_document")
  @@index([taskId], name: "idx_history_task")
  @@index([traceId], name: "idx_history_trace")
  @@map("execution_history")
}

// ============================================================
// NEW: TASK RETRY TRACKING
// ============================================================

model TaskRetry {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId        String    @map("task_id") @db.Uuid
  attemptNumber Int       @map("attempt_number")
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt   DateTime? @map("completed_at") @db.Timestamptz
  state         TaskState
  errorMessage  String?   @map("error_message")
  errorStack    String?   @map("error_stack")
  workerId      String?   @map("worker_id")
  workerHost    String?   @map("worker_host")
  metadata      Json      @default("{}")

  // Relations
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, attemptNumber], name: "unique_task_attempt")
  @@index([taskId], name: "idx_retries_task")
  @@index([startedAt(sort: Desc)], name: "idx_retries_started")
  @@map("task_retries")
}

// ============================================================
// PHASE 12.1: PROVENANCE + LINEAGE
// ============================================================

model Derivation {
  id               String   @id @default(uuid()) @db.Uuid
  // Output side — which node in which generated workspace
  workspaceId      String   @map("workspace_id") @db.Uuid
  generatedNodeId  String   @map("generated_node_id")
  generatedDocPath String?  @map("generated_doc_path")
  // Source side
  sourceDocumentId String?  @map("source_document_id") @db.Uuid
  sourceChapterId  String?  @map("source_chapter_id") @db.Uuid
  sourceSectionId  String?  @map("source_section_id") @db.Uuid
  pageNumbers      Int[]    @default([]) @map("page_numbers")
  textExcerpt      String?  @map("text_excerpt")
  // Activity (PROV-O)
  skill            String
  model            String
  promptHash       String?  @map("prompt_hash")
  confidence       Float?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  sourceDocument   Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([workspaceId], name: "idx_derivation_workspace")
  @@index([generatedNodeId], name: "idx_derivation_node")
  @@index([sourceDocumentId], name: "idx_derivation_source_doc")
  @@map("derivations")
}

model DocumentRevision {
  id               String   @id @default(uuid()) @db.Uuid
  workspaceId      String   @map("workspace_id") @db.Uuid
  parentRevisionId String?  @map("parent_revision_id") @db.Uuid
  revisionNumber   Int      @map("revision_number")
  op               String
  payload          Json     @default("{}")
  actor            String?
  snapshotPath     String?  @map("snapshot_path")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  parent   DocumentRevision?  @relation("RevisionParent", fields: [parentRevisionId], references: [id], onDelete: SetNull)
  children DocumentRevision[] @relation("RevisionParent")

  @@unique([workspaceId, revisionNumber], name: "uq_revision_workspace_n")
  @@index([workspaceId], name: "idx_revision_workspace")
  @@index([parentRevisionId], name: "idx_revision_parent")
  @@map("document_revisions")
}

model SkillInvocation {
  id               String   @id @default(uuid()) @db.Uuid
  skill            String
  model            String?
  workspaceId      String?  @map("workspace_id") @db.Uuid
  inputs           Json     @default("{}")
  outputs          Json     @default("{}")
  status           String
  errorMessage     String?  @map("error_message")
  actor            String?
  startedAt        DateTime @default(now()) @map("started_at") @db.Timestamptz(6)
  durationMs       Int?     @map("duration_ms")
  promptTokens     Int?     @map("prompt_tokens")
  completionTokens Int?     @map("completion_tokens")

  @@index([skill], name: "idx_skill_inv_name")
  @@index([workspaceId], name: "idx_skill_inv_workspace")
  @@index([startedAt], name: "idx_skill_inv_started")
  @@map("skill_invocations")
}

// ============================================================
// PHASE 38: PIPELINE ORCHESTRATION
// ============================================================

enum PipelineRunState {
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELLED

  @@map("pipeline_run_state")
}

model PipelineRun {
  id           String           @id @default(uuid()) @db.Uuid
  name         String?
  spec         Json             @default("{}")
  state        PipelineRunState @default(QUEUED)
  parameters   Json             @default("{}")
  actor        String?
  errorMessage String?          @map("error_message")
  startedAt    DateTime         @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime?        @map("finished_at") @db.Timestamptz(6)

  steps PipelineStep[]

  @@index([state], name: "idx_pipeline_run_state")
  @@index([startedAt], name: "idx_pipeline_run_started")
  @@map("pipeline_runs")
}

model PipelineStep {
  id           String           @id @default(uuid()) @db.Uuid
  runId        String           @map("run_id") @db.Uuid
  stepIndex    Int              @map("step_index")
  alias        String?
  skill        String
  inputs       Json             @default("{}")
  outputs      Json             @default("{}")
  state        PipelineRunState @default(QUEUED)
  errorMessage String?          @map("error_message")
  startedAt    DateTime?        @map("started_at") @db.Timestamptz(6)
  finishedAt   DateTime?        @map("finished_at") @db.Timestamptz(6)
  durationMs   Int?             @map("duration_ms")

  run PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@unique([runId, stepIndex], name: "uq_pipeline_step_run_idx")
  @@index([runId], name: "idx_pipeline_step_run")
  @@map("pipeline_steps")
}

// ============================================================
// PHASE 41: DOCUMENT TAGS
// ============================================================

model Tag {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @unique          // lowercase, kebab-case enforced at API
  color       String?       @default("#5EFCAB")
  description String?
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  documents   DocumentTag[]

  @@index([name], name: "idx_tag_name")
  @@map("tags")
}

model DocumentTag {
  documentId  String   @map("document_id") @db.Uuid
  tagId       String   @map("tag_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  actor       String?

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag         Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([documentId], name: "idx_document_tag_doc")
  @@index([tagId], name: "idx_document_tag_tag")
  @@map("document_tags")
}

// ============================================================
// PHASE 42: EVENT BUS + TRIGGERS
// ============================================================

enum TriggerStatus {
  ENABLED
  DISABLED

  @@map("trigger_status")
}

model Trigger {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  description  String?
  eventType    String        @map("event_type")
  filter       Json          @default("{}")
  pipelineSpec Json          @default("{}") @map("pipeline_spec")
  status       TriggerStatus @default(ENABLED)
  actor        String?
  fireCount    Int           @default(0) @map("fire_count")
  lastFiredAt  DateTime?     @map("last_fired_at") @db.Timestamptz(6)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType], name: "idx_trigger_event_type")
  @@index([status], name: "idx_trigger_status")
  @@map("triggers")
}

model EventLog {
  id                 String   @id @default(uuid()) @db.Uuid
  eventType          String   @map("event_type")
  payload            Json     @default("{}")
  source             String?
  matchedTriggerIds  String[] @default([]) @map("matched_trigger_ids")
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([eventType], name: "idx_event_log_type")
  @@index([createdAt], name: "idx_event_log_created")
  @@map("event_logs")
}

// ============================================================
// PHASE 44: RETENTION POLICIES + LEGAL HOLD + DISPOSITION
// ============================================================

enum DispositionAction {
  ARCHIVE
  DESTROY
  REVIEW

  @@map("disposition_action")
}

model RetentionPolicy {
  id              String            @id @default(uuid()) @db.Uuid
  name            String            @unique
  description     String?
  durationDays    Int               @map("duration_days")
  action          DispositionAction @default(REVIEW)
  startTrigger    String            @default("created_at") @map("start_trigger")
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  applied DocumentRetention[]

  @@index([name], name: "idx_retention_policy_name")
  @@map("retention_policies")
}

model DocumentRetention {
  id                String          @id @default(uuid()) @db.Uuid
  documentId        String          @map("document_id") @db.Uuid
  policyId          String          @map("policy_id") @db.Uuid
  startAt           DateTime        @map("start_at") @db.Timestamptz(6)
  dispositionDueAt  DateTime        @map("disposition_due_at") @db.Timestamptz(6)
  legalHold         Boolean         @default(false) @map("legal_hold")
  legalHoldReason   String?         @map("legal_hold_reason")
  disposed          Boolean         @default(false)
  disposedAt        DateTime?       @map("disposed_at") @db.Timestamptz(6)
  actor             String?
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  document  Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  policy    RetentionPolicy @relation(fields: [policyId], references: [id], onDelete: Restrict)
  events    DispositionEvent[]

  @@index([documentId], name: "idx_doc_retention_doc")
  @@index([dispositionDueAt], name: "idx_doc_retention_due")
  @@index([legalHold], name: "idx_doc_retention_hold")
  @@unique([documentId, policyId], name: "uq_doc_retention_doc_policy")
  @@map("document_retentions")
}

model DispositionEvent {
  id             String            @id @default(uuid()) @db.Uuid
  retentionId    String            @map("retention_id") @db.Uuid
  action         DispositionAction
  status         String
  reason         String?
  actor          String?
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  retention DocumentRetention @relation(fields: [retentionId], references: [id], onDelete: Cascade)

  @@index([retentionId], name: "idx_disposition_event_retention")
  @@index([createdAt], name: "idx_disposition_event_created")
  @@map("disposition_events")
}
