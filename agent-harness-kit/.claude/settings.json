{
  "permissions": {
    "allow": [
      "Bash(docker compose exec -T backend uv run ruff *)",
      "Bash(docker compose exec -T backend uvx ty check *)",
      "Bash(docker compose exec -T backend uv run pytest *)",
      "Bash(docker compose exec -T backend uv run python -m checks *)",
      "Bash(cd {{FRONTEND_DIR}} *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/quality-gate.sh\" mark-edit"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/quality-gate.sh\" check-bash"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/quality-gate.sh\" stop-gate"
          }
        ]
      }
    ]
  }
}
