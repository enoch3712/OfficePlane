#!/usr/bin/env bash
# Git pre-commit hook — runs quality checks scoped to staged files.
#
# Detects which files are staged and runs only the relevant checks:
#   - Backend .py files  → ./scripts/check-all.sh backend
#   - Frontend .ts/.tsx  → ./scripts/check-all.sh frontend
#   - Docs .md files     → ./scripts/check-all.sh docs
#   - Mixed              → ./scripts/check-all.sh with appropriate scopes
#   - None of the above  → skip checks, allow commit
#
# Setup: ./scripts/setup-hooks.sh (configures git to use .githooks/)
# Bypass: git commit --no-verify

set -euo pipefail

# Resolve project root (two levels up from .githooks/pre-commit)
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$HOOK_DIR")"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
NC='\033[0m'

echo -e "${BLUE}pre-commit: scanning staged files...${NC}"

# Get staged file names relative to project root
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}pre-commit: no staged files — skipping checks${NC}"
  exit 0
fi

# Detect which scopes have staged changes
HAS_BACKEND=false
HAS_FRONTEND=false
HAS_DOCS=false

while IFS= read -r file; do
  if echo "$file" | grep -qE '^agent_builder_backend/.*\.py$'; then
    HAS_BACKEND=true
  fi
  if echo "$file" | grep -qE '^agent_builder_frontend/.*\.(ts|tsx)$'; then
    HAS_FRONTEND=true
  fi
  if echo "$file" | grep -qE '\.(md)$'; then
    HAS_DOCS=true
  fi
done <<< "$STAGED_FILES"

if ! $HAS_BACKEND && ! $HAS_FRONTEND && ! $HAS_DOCS; then
  echo -e "${GREEN}pre-commit: no .py, .ts/.tsx, or .md files staged — skipping checks${NC}"
  exit 0
fi

# Build scopes list
SCOPES=()
$HAS_BACKEND && SCOPES+=("backend")
$HAS_FRONTEND && SCOPES+=("frontend")
$HAS_DOCS && SCOPES+=("docs")

echo -e "${BLUE}pre-commit: detected scopes: ${SCOPES[*]}${NC}"

# Verify check-all.sh exists
CHECK_SCRIPT="$PROJECT_ROOT/scripts/check-all.sh"
if [ ! -x "$CHECK_SCRIPT" ]; then
  echo -e "${RED}pre-commit: scripts/check-all.sh not found or not executable${NC}"
  echo -e "${YELLOW}  Bypass with: git commit --no-verify${NC}"
  exit 1
fi

# For backend scope, verify Docker is running
if $HAS_BACKEND; then
  if ! docker compose ps --status running 2>/dev/null | grep -q "backend"; then
    echo -e "${RED}pre-commit: Docker backend container is not running${NC}"
    echo -e "${YELLOW}  Start with: ./scripts/dev.sh${NC}"
    echo -e "${YELLOW}  Bypass with: git commit --no-verify${NC}"
    exit 1
  fi
fi

# Run quality checks for each scope
HOOK_FAILED=false
for SCOPE in "${SCOPES[@]}"; do
  echo -e "${BLUE}pre-commit: running ./scripts/check-all.sh ${SCOPE}${NC}"
  if ! "$CHECK_SCRIPT" "$SCOPE"; then
    HOOK_FAILED=true
  fi
done

if $HOOK_FAILED; then
  echo ""
  echo -e "${RED}pre-commit: quality checks failed — commit blocked${NC}"
  echo -e "${YELLOW}  Fix the issues above, then stage and commit again.${NC}"
  echo -e "${YELLOW}  Bypass with: git commit --no-verify${NC}"
  exit 1
else
  echo -e "${GREEN}pre-commit: all checks passed${NC}"
  exit 0
fi
