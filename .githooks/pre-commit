#!/usr/bin/env bash
# Git pre-commit hook — runs quality checks scoped to staged files.
#
# Setup: ./scripts/setup-hooks.sh
# Bypass: git commit --no-verify

set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$HOOK_DIR")"

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[0;33m'
NC='\033[0m'

echo -e "${BLUE}pre-commit: scanning staged files...${NC}"

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$STAGED_FILES" ]; then
  echo -e "${GREEN}pre-commit: no staged files — skipping checks${NC}"
  exit 0
fi

HAS_BACKEND=false
HAS_FRONTEND=false

while IFS= read -r file; do
  if echo "$file" | grep -qE '^src/.*\.py$'; then
    HAS_BACKEND=true
  fi
  if echo "$file" | grep -qE '^ui/.*\.(ts|tsx)$'; then
    HAS_FRONTEND=true
  fi
done <<< "$STAGED_FILES"

if ! $HAS_BACKEND && ! $HAS_FRONTEND; then
  echo -e "${GREEN}pre-commit: no .py or .ts/.tsx files staged — skipping checks${NC}"
  exit 0
fi

SCOPES=()
$HAS_BACKEND && SCOPES+=("backend")
$HAS_FRONTEND && SCOPES+=("frontend")

echo -e "${BLUE}pre-commit: detected scopes: ${SCOPES[*]}${NC}"

CHECK_SCRIPT="$PROJECT_ROOT/scripts/check-all.sh"
if [ ! -x "$CHECK_SCRIPT" ]; then
  echo -e "${RED}pre-commit: scripts/check-all.sh not found or not executable${NC}"
  echo -e "${YELLOW}  Bypass with: git commit --no-verify${NC}"
  exit 1
fi

# For backend, verify Docker is running
if $HAS_BACKEND; then
  if ! docker compose ps --status running 2>/dev/null | grep -q "api"; then
    echo -e "${RED}pre-commit: Docker API container is not running${NC}"
    echo -e "${YELLOW}  Start with: docker compose up -d${NC}"
    echo -e "${YELLOW}  Bypass with: git commit --no-verify${NC}"
    exit 1
  fi
fi

HOOK_FAILED=false
for SCOPE in "${SCOPES[@]}"; do
  echo -e "${BLUE}pre-commit: running ./scripts/check-all.sh ${SCOPE}${NC}"
  if ! "$CHECK_SCRIPT" "$SCOPE"; then
    HOOK_FAILED=true
  fi
done

if $HOOK_FAILED; then
  echo ""
  echo -e "${RED}pre-commit: quality checks failed — commit blocked${NC}"
  echo -e "${YELLOW}  Fix the issues above, then stage and commit again.${NC}"
  echo -e "${YELLOW}  Bypass with: git commit --no-verify${NC}"
  exit 1
else
  echo -e "${GREEN}pre-commit: all checks passed${NC}"
  exit 0
fi
